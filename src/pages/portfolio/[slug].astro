---
import 'photoswipe/style.css';
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Carousel from '$lib/components/Carousel.svelte';
import { formatDate, isValidISODateString } from '$lib/utils/dateUtils';

export async function getStaticPaths() {
	const allProjects = await getCollection('portfolio');
	return allProjects.map((project) => ({ params: { slug: project.id } }));
}

const { slug } = Astro.params;
const project = await getEntry('portfolio', slug!);

if (!project) {
	throw new Error('Invalid slug');
}
---

<BaseLayout>
	<article class="project">
		<a class="btn-back" href="/portfolio"><i class="feathericon-arrow-left"></i>Back to Portfolio</a
		>

		<header class="header-project">
			<h1 class="title title--h1">
				<a
					href={project.data.websiteUrl}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`View ${project.data.listName} website`}>{project.data.listName}</a
				>
			</h1>
			<div class="header-project__image-wrap">
				<img
					class="cover"
					src={project.data.cover.src}
					alt={project.data.cover.alt}
					width={project.data.cover.width}
					height={project.data.cover.height}
				/>
			</div>
		</header>

		<ul class="details-info details-info--inline">
			{
				project.data.infoBlocks.map((infoBlock) => (
					<li class="details-info__item">
						<span class="box icon-box">
							<i class={`font-icon ${infoBlock.icon}`} />
						</span>
						<div class="details-info__info">
							<span class="overhead">{infoBlock.title}</span>
							{isValidISODateString(infoBlock.content) ? (
								<span>{formatDate(infoBlock.content)}</span>
							) : (
								<span>{infoBlock.content}</span>
							)}
						</div>
					</li>
				))
			}
		</ul>

		<section class="carousel">
			<Carousel
				client:visible
				swiperId="swiper-gallery"
				slidesPerView="auto"
				slides={project.data.images}
				centeredSlides={true}
				speed={300}
				breakpoints={{
					580: { slidesPerView: 'auto', spaceBetween: 20 }
				}}
			/>
		</section>

		<section class="project-copy" set:html={project.rendered?.html} />
	</article>
</BaseLayout>

<script>
	import PhotoSwipeLightbox from 'photoswipe/lightbox';

	const lightbox = new PhotoSwipeLightbox({
		gallery: '#swiper-gallery',
		children: 'a',
		showHideAnimationType: 'fade',
		pswpModule: () => import('photoswipe')
	});
	lightbox.init();
</script>

<style lang="scss">
	@use 'styles/app/single-project';

	.details-info {
		margin-bottom: 1.5rem;
		@media only screen and (max-width: $small) {
			margin-bottom: 1rem;
		}
	}

	.carousel {
		margin-bottom: 2rem;
		@media only screen and (max-width: $small) {
			margin-bottom: 1rem;
		}
	}
</style>
