---
import { getImage } from 'astro:assets';
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Expertise from '$lib/components/Expertise.astro';
import Carousel from '$lib/components/Carousel.astro';
import type { Expertise as ExpertiseType } from '#types/Expertise';
import type { ReviewData as ReviewDataType, ClientData as ClientType } from '#types/Carousel';

const aboutEntry = await getEntry('site', 'about');

const expertise: ExpertiseType = {
	heading: 'My Expertise',
	expertiseCases: [
		{
			name: 'Web Development',
			icon: '/images/icons/icon-dev.svg',
			iconAlt: 'Web Development',
			description: 'Professional-grade website development.'
		},
		{
			name: 'Project Management',
			icon: '/images/icons/icon-design.svg',
			iconAlt: 'Project Management',
			description: 'Planning, organizing, executing, and fulfilling web projects.'
		},
		{
			name: 'Web Apps',
			icon: '/images/icons/icon-framework.svg',
			iconAlt: 'Web Apps',
			description: 'Web applications development with Laravel, Symfony and Ruby on Rails.'
		},
		{
			name: 'AI-Orchestrated Development',
			icon: '/images/icons/icon-sparkle.svg',
			iconAlt: 'AI-Orchestrated Development',
			description: 'Directing AI coding agents to design, build, and ship production web apps.'
		}
	]
};

const testimonialEntries = (await getCollection('testimonials')).sort(
	(a, b) => a.data.order - b.data.order
);
const testimonials: ReviewDataType[] = await Promise.all(
	testimonialEntries.map(async (entry) => {
		const avatar = await getImage({ src: entry.data.image, width: 160, height: 160 });
		return {
			name: entry.data.name,
			image: avatar.src,
			imageWidth: avatar.attributes.width,
			imageHeight: avatar.attributes.height,
			imageAlt: entry.data.imageAlt,
			shortCopy: entry.data.shortCopy,
			copy: entry.rendered?.html ?? '',
			reviewDate: entry.data.reviewDate
		};
	})
);

const clients: ClientType[] = [
	{
		link: 'https://greymass.com/',
		logo: '/images/clients/greymass-color.svg',
		logoAlt: 'Greymass logo'
	},
	{
		link: 'https://bullish.com',
		logo: '/images/clients/bullish-color.svg',
		logoAlt: 'Bullish logo'
	},
	{
		link: 'https://b1.com',
		logo: '/images/clients/b1-color.svg',
		logoAlt: 'b1 logo'
	},
	{
		link: 'https://about.voice.com/company/',
		logo: '/images/clients/voice-color.svg',
		logoAlt: 'Voice logo'
	},
	{
		link: 'https://eos.io',
		logo: '/images/clients/eosio-color.svg',
		logoAlt: 'eosio logo'
	},
	{
		link: 'https://grafik.agency',
		logo: '/images/clients/grafik-color.svg',
		logoAlt: 'Grafik logo'
	}
];
---

<BaseLayout>
	<section class="about" set:html={aboutEntry?.rendered?.html} />

	<section class="expertise">
		<h2 class="title title--h2">{expertise.heading}</h2>
		<div class="row">
			<Expertise expertiseCases={expertise.expertiseCases} />
		</div>
	</section>

	<section class="swiper-testimonials">
		<h2 class="title title--h2">Testimonials</h2>
		<Carousel
			swiperId="swiper-testimonials"
			slides={testimonials}
			breakpoints={{
				580: { slidesPerView: 1, spaceBetween: 20 },
				991: { slidesPerView: 2 }
			}}
		/>
	</section>

	<section class="swiper-clients">
		<h2 class="title title--h2">Clients</h2>
		<Carousel
			swiperId="swiper-clients"
			slides={clients}
			breakpoints={{
				320: { slidesPerView: 2, spaceBetween: 0 },
				580: { slidesPerView: 3, spaceBetween: 30 },
				991: { slidesPerView: 4, spaceBetween: 30 }
			}}
		/>
	</section>
</BaseLayout>

<style lang="scss">
	.about {
		margin-bottom: 2.5rem;
	}
	.expertise {
		margin-bottom: 1rem;
	}
	.swiper-testimonials {
		margin-bottom: 1rem;
	}
</style>
