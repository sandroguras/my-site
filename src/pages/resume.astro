---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '$lib/components/Timeline.astro';
import Skillset from '$lib/components/Skillset.astro';
import type { Skillset as SkillsetType } from '#types/Skillset';
import type { TimelineEvent as TimelineEventType } from '#types/Timeline';

const softSkills: SkillsetType['skills'] = [
	{ name: 'Team Coordination' },
	{ name: 'Project Oversight' },
	{ name: 'Agile Leadership' },
	{ name: 'Scrum Mastery' },
	{ name: 'Stakeholder Liaison' },
	{ name: 'Delivery Management' },
	{ name: 'AI Integration' },
	{ name: 'Jira' },
	{ name: 'ClickUp' },
	{ name: 'Basecamp' },
	{ name: 'Asana' },
	{ name: 'Trello' }
];
const hardSkills: SkillsetType['skills'] = [
	{ name: 'AWS' },
	{ name: 'GCP' },
	{ name: 'TypeScript' },
	{ name: 'JavaScript' },
	{ name: 'PHP' },
	{ name: 'Ruby' },
	{ name: 'C#' },
	{ name: 'React' },
	{ name: 'Next.js' },
	{ name: 'WordPress' },
	{ name: 'Symfony' },
	{ name: 'Laravel' },
	{ name: 'Ruby on Rails' },
	{ name: 'MySQL' },
	{ name: 'PostgreSQL' },
	{ name: 'MongoDB' },
	{ name: 'AI-Assisted Development' },
	{ name: 'Claude Code' },
	{ name: 'Prompt Engineering' }
];

function toTimelineEvent(entry: CollectionEntry<'timeline'>): TimelineEventType {
	return {
		id: entry.data.order,
		institution: entry.data.institution,
		institutionUrl: entry.data.institutionUrl,
		position: entry.data.position,
		period: entry.data.period,
		description: entry.rendered?.html ?? ''
	};
}

const allTimelineEntries = await getCollection('timeline');
const experience = allTimelineEntries
	.filter((entry) => entry.data.section === 'experience')
	.sort((a, b) => b.data.order - a.data.order)
	.map(toTimelineEvent);
const education = allTimelineEntries
	.filter((entry) => entry.data.section === 'education')
	.sort((a, b) => b.data.order - a.data.order)
	.map(toTimelineEvent);
---

<BaseLayout>
	<section class="experience">
		<Timeline heading="Experience" logo="feathericon-briefcase" timelineEvents={experience} />
	</section>

	<section class="education">
		<Timeline heading="Education" logo="feathericon-book-open" timelineEvents={education} />
	</section>

	<section class="skillset">
		<h2 class="title title--h2">Soft Skills</h2>
		<Skillset skills={softSkills} />
	</section>
	<section class="skillset">
		<h2 class="title title--h2">Hard Skills</h2>
		<Skillset skills={hardSkills} />
	</section>
</BaseLayout>

<style lang="scss">
	section:nth-of-type(3) {
		margin-bottom: 3rem;
		@media only screen and (max-width: $small) {
			margin-bottom: 2.5rem;
		}
	}

	section:nth-of-type(4) {
		margin-bottom: 0;
	}

	.education {
		margin-bottom: 3rem;

		@media only screen and (max-width: $small) {
			margin-bottom: 2.5rem;
		}
	}
</style>
