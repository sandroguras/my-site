---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Form from '$lib/components/Form.svelte';

const conclusionEntry = await getEntry('site', 'contact');
---

<BaseLayout>
	<section class="copy" set:html={conclusionEntry?.rendered?.html} />

	<Form client:load />
</BaseLayout>

<style lang="scss">
	.copy {
		margin-bottom: 2.5rem;
	}
</style>
