---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '$lib/utils/dateUtils';

const allPosts = await getCollection('blog');
const posts = allPosts
	.map((entry) => ({
		slug: entry.id,
		listName: entry.data.listName,
		thumb: entry.data.thumb,
		category: entry.data.category,
		date: entry.data.date,
		excerpt: entry.data.excerpt
	}))
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout>
	<div class="news-grid">
		{
			posts.map((post) => (
				<article class="news-item box">
					<div class="news-item__image-wrap">
						<a class="news-item__link" href={`/blog/${post.slug}`}>
							<img
								class="cover"
								src={post.thumb.src}
								alt={post.thumb.alt}
								width={post.thumb.width}
								height={post.thumb.height}
								loading="lazy"
							/>
						</a>
					</div>
					<div class="news-item__caption">
						<div class="news-item__date">
							<span>{post.category}</span>
							{formatDate(post.date)}
						</div>
						<h2 class="title title--h2">
							<a href={`/blog/${post.slug}`}>{post.listName}</a>
						</h2>
						<p>{post.excerpt}</p>
					</div>
				</article>
			))
		}
	</div>
</BaseLayout>

<style lang="scss">
	@use 'styles/app/news';
</style>
